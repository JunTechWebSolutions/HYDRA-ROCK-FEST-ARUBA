          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": "zen2cool-blocks/components",
          "_isSecondary": true,
          "typeCompatible": "type",
          "_styles": {
            "& when (@Whatbutton)": {
              ".float": {
                "position": "fixed",
                "width": "(@widthwhat * 1px)",
                "height": "(@heightwhat * 1px)",
                "bottom": "(@bottomwhat * 1px)",
                "right": "(@rightwhat * 1px)",
                "background-color": "@bgcolorwhat",
                "color": "@colorwhat",
                "border-radius": "(@borderadius * 1px)",
                "text-align": "center",
                "font-size": "(@FontSize * 1px)",
                "box-shadow": "2px 2px 3px #999",
                "z-index": "100"
              },
              ".my-float": {
                "margin-top": "16px"
              }
            },
            "P": {
              "color": "#232323"
            },
            "DIV": {
              "color": "#ffffff"
            },
            "H10": {
              "color": "#767676"
            },
            ".hidden": {
              "display": "none"
            }
          },
          "_name": "whatsbutton",
          "_sourceTheme": "mobirise5",
          "_customHTML": "<section mbr-id=\"_anchor\" class=\"_customHTML\">\n \n  \n    <mbr-parameters>\n<hr><header>Whatsapp Config</header>\n      <input type=\"checkbox\" title=\"Whatsapp Button\" name=\"Whatbutton\" checked>\n      <input type=\"text\" name=\"Phonenumber\" title=\"Phone number\" value=\"+2977430439\" condition=\"Whatbutton\">\n      <input type=\"text\" name=\"Textewhatapp\" title=\"Your Text\" value=\"Hello! For more information about HYDRA ROCK FEST, please check out our Facebook page.\" condition=\"Whatbutton\">\n        <input type=\"range\" inline title=\"Height\" name=\"heightwhat\" min=\"0\" max=\"100\" step=\"1\" value=\"60\" condition=\"Whatbutton\">\n        <input type=\"range\" inline title=\"Width\" name=\"widthwhat\" min=\"0\" max=\"100\" step=\"1\" value=\"60\" condition=\"Whatbutton\">\n              <input type=\"range\" inline title=\"Bottom\" name=\"bottomwhat\" min=\"0\" max=\"250\" step=\"1\" value=\"40\" condition=\"Whatbutton\">\n              <input type=\"range\" inline title=\"Right\" name=\"rightwhat\" min=\"0\" max=\"250\" step=\"1\" value=\"100\" condition=\"Whatbutton\">\n        <input type=\"range\" inline title=\"border-radius\" name=\"borderadius\" min=\"1\" max=\"100\" step=\"1\" value=\"60\" condition=\"Whatbutton\">\n        <input type=\"color\" title=\"Background Color\" name=\"bgcolorwhat\" value=\"#25d366\" condition=\"Whatbutton\">\n        <input type=\"color\" title=\"Color\" name=\"colorwhat\" value=\"#ffffff\" condition=\"Whatbutton\">\n      <input type=\"range\" title=\"Font Size\" name=\"FontSize\" min=\"0\" max=\"100\" step=\"1\" value=\"30\" condition=\"Whatbutton\">\n            \n    </mbr-parameters> \n  <div class=\"whatapp\" mbr-if=\"Whatbutton\">\n\t\t<link rel=\"stylesheet\" href=\"https://maxcdn.bootstrapcdn.com/font-awesome/4.5.0/css/font-awesome.min.css\">\n<a href=\"https://api.whatsapp.com/send?phone={{Phonenumber}}&text={{Textewhatapp}}\" class=\"float\" target=\"_blank\">\n<i class=\"fa fa-whatsapp my-float\"></i>\n</a>\n\t</div>\n  \n\n\n\n <div mbr-class=\"{'hidden': isPublish}\" style=\"padding:1rem; background-color:#c1c1c1;\">\n   <div class=\"align-center\">\n       <h10>\n          <br>\n           <br><br><br><br><br>Whatsapp Button<br><br>Click the \"gear\" icon to change the layout of the Whatsapp Button. This text will be removed on preview/publish.<br><br>\n\n<svg id=\"svg\" version=\"1.1\" xmlns=\"http://www.w3.org/2000/svg\" xmlns:xlink=\"http://www.w3.org/1999/xlink\" width=\"150\" viewBox=\"0, 0, 400,383.33333333333337\">\n<g id=\"svgg\">\n<path id=\"path0\" d=\"M37.210 6.152 C 35.603 6.521,34.673 7.586,34.092 9.720 C 33.330 12.516,33.825 95.736,34.612 97.241 C 35.870 99.644,28.382 99.467,134.420 99.600 C 199.138 99.681,231.925 99.852,232.882 100.115 C 235.440 100.816,235.350 101.661,230.295 124.449 C 224.368 151.170,212.070 208.952,209.422 222.521 C 207.800 230.833,207.905 232.790,209.971 232.790 C 211.891 232.790,209.325 235.910,254.122 179.099 C 277.812 149.054,289.953 133.596,295.689 126.174 C 297.890 123.327,306.521 112.368,314.870 101.822 C 367.957 34.759,386.363 11.054,386.765 9.224 C 387.073 7.820,386.446 6.596,385.169 6.111 C 383.972 5.656,39.193 5.697,37.210 6.152 M382.917 8.569 C 384.519 9.741,380.855 14.580,323.489 87.057 C 313.389 99.818,299.260 117.766,292.092 126.942 C 279.051 143.636,265.977 160.258,245.456 186.236 C 239.439 193.853,229.856 206.001,224.162 213.231 C 210.292 230.840,210.188 230.897,212.490 219.587 C 217.028 197.295,227.371 148.754,232.598 125.216 C 237.896 101.359,238.065 99.524,235.099 97.991 C 234.120 97.484,228.193 97.405,188.034 97.358 C 75.294 97.227,37.576 96.911,36.978 96.092 C 36.161 94.974,36.161 10.490,36.978 9.373 C 37.513 8.642,38.883 8.626,116.843 8.435 C 301.952 7.984,382.171 8.024,382.917 8.569 M81.622 108.821 C 107.636 108.875,150.091 108.875,175.966 108.821 C 201.840 108.766,180.556 108.722,128.667 108.722 C 76.779 108.722,55.608 108.766,81.622 108.821 M177.885 157.718 C 177.1